# ============================================================
# AutoAPI-AK-Core — Root .env.example
# Скопируйте в .env и заполните значения
# НЕ КОММИТИТЬ .env в git!
# ============================================================

# === ОБЩИЕ ===
ENV=development                        # development | staging | production
LOG_LEVEL=debug                        # debug | info | warn | error

# === POSTGRES ===
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=autoapi
POSTGRES_USER=autoapi
POSTGRES_PASSWORD=changeme_local

# === REDIS ===
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# === JWT ===
JWT_SECRET=changeme_very_long_secret_at_least_32_chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# === ШИФРОВАНИЕ КЛЮЧЕЙ АККАУНТОВ ===
VAULT_MASTER_KEY=changeme_32_byte_hex_key_here_0000

# === СЕРВИСНЫЕ ПОРТЫ ===
GATEWAY_PORT=3000
AUTH_PORT=3001
ACCOUNT_VAULT_PORT=3002
ROUTER_PORT=8080
CONTEXT_BRIDGE_PORT=8081
